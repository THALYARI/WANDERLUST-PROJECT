<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2" >
<body>
    <br>
    <h2>Create A new Listing</h2>
    <br>
    <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data"> <!-- novalidate will remove the browser default validation like if we dont enter name it will say name is required which is default .. it will remove this so we can add our custom validation from bootstrap -->
        <div class="mb-3">                                                      <!-- this enctype will help the user to send files through form-->
        <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]" placeholder="Enter Title" class="form-control" required>
        <div class="invalid-feedback">Title can't be Empty</div>
        <div class="valid-feedback">Title looks good</div>
        </div>
        
        <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea type="text" name="listing[description]" placeholder="Enter Description" class="form-control" required></textarea>
        <div class="invalid-feedback">Invalid Description</div>
        </div>
        
        <div class="mb-3">
        <label for="image" class="form-label">Upload Listing Image</label> 
        <input type="file" name="image" class="form-control" required>
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input type="number" name="listing[price]" placeholder="Eg-1200" class="form-control" required>
        <div class="invalid-feedback">Invalid Price</div>
        </div>
        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Country</label>
        <input type="text" name="listing[country]" placeholder="Eg-India" class="form-control" required>
        <div class="invalid-feedback">Invalid Country</div>        
        </div>
        </div>


        <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input type="text" name="listing[location]" placeholder="Eg-Shimla,H.P" class="form-control" required>
        <div class="invalid-feedback">Location is invalid</div>        
        </div>
        <button class="btn btn-dark add-btn mt-3">ADD</button>
    </form>
    <br><br>
</div>
</div>